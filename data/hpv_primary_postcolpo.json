    {
      "function1": "is_hpv_genotyped = (r) => r == 'HPV 16+' || r == 'HPV 18+'",
      "function2": "is_hpv_positive = (r) => is_hpv_genotyped(r) || r.startsWith('HPV+')"
    },
    {
      "situation": "clinical_situation.indexOf('treatment') >= 0 ? 'posttreatment' : 'postcolposcopy'",
      "_colpo": "second == 'No CIN' ? 'NO CIN' : second == 'Histologic LSIL (CIN 1)' ? 'CIN 1' : second == 'Histologic HSIL (CIN 2)' ? 'CIN 2' : second == 'Histologic HSIL (CIN 3 or Unspecified)' ? 'CIN 3' : second == 'AIS' ? 'AIS' : ''",
      "colpo": "situation == 'postcolposcopy' ? _colpo : ((_colpo == 'NO CIN' || _colpo == 'CIN 1') && ['ASC-H', 'HSIL', 'AGC'].indexOf(treatment) >= 0) ? 'CIN01H' : _colpo",
      "current_hpv": "hpv",
      "current_cytology": "positive_results == 'None' ? 'None' : cytology"
    },
    {
      "_current_both": "(is_hpv_positive(hpv) && patient_age != 'Under 25' && positive_results == 'Both') ? pos_both : (positive_results == 'None' ? 'None' : cytology)",
      "_current_ds": "(is_hpv_positive(hpv) && patient_age != 'Under 25' && positive_results == 'Dual Stain') ? dual_stain : 'None'"
    },
    {
      "_cytology": "_current_ds  != 'None' ? _current_ds : _current_both",
      "short": "situation == 'posttreatment' ? 'Post-treatment' : 'Post-colposcopy'"
    }
