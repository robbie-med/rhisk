  "derived": [
    {
      "function1": "is_hpv_genotyped = (r) => r == 'HPV 16+' || r == 'HPV 18+'",
      "function2": "is_hpv_positive = (r) => is_hpv_genotyped(r) || r.startsWith('HPV+')",
      "function3": "eval_cytology_ds = (cyt, ds) => (cyt == 'None' && ds == 'None') ? 'None' : ['ASC-H or HSIL', 'ASC-H', 'HSIL', 'AGC'].indexOf(cyt) >= 0 ? cyt : (ds == 'Dual Stain Positive' || ['ASC-US', 'LSIL'].indexOf(cyt) >= 0) ? 'Low Grade Cytology and/or Dual Stain +' : (ds == 'Dual Stain Negative' || cyt == 'Normal') ? 'Normal Cytology or Dual Stain -' : cyt",
      "function4": "eval_hpv_cytology_ds = (hp, cyt, ds) => (cyt == 'None' && ds == 'None') ? 'None' : ['ASC-H or HSIL', 'ASC-H', 'HSIL', 'AGC'].indexOf(cyt) >= 0 ? cyt : (ds == 'Dual Stain Positive' || ['ASC-US', 'LSIL'].indexOf(cyt) >= 0) ? 'Low Grade Cytology and/or Dual Stain +' : (ds == 'Dual Stain Negative' || cyt == 'Normal') ? 'Normal Cytology or Dual Stain -' : cyt"
    },
    {
      "current_hpv": "hpv",
      "current_cytology": "!is_hpv_positive(hpv) ? '' : current_agc ? 'AGC' : current_hsil ? 'HSIL' : current_asc_h ? 'ASC-H' : current_lsil ? 'LSIL' : current_asc_us ? 'ASC-US' : current_normal ? 'Normal' : 'None'",
      "_cytology": "(hpv == 'None' && cytology1.length) ? cytology1 : (hpv == 'HPV-' && cytology2.length) ? cytology2 : (is_hpv_positive(hpv) && current_cytology.length) ? current_cytology : ''",
      "current_ds": "!is_hpv_positive(hpv) ? '' : current_dual_stain_positive ? 'Dual Stain Positive' : current_dual_stain_negative ? 'Dual Stain Negative' : 'None'",
      "current_cytology_or_ds": "is_hpv_positive(hpv) ? eval_cytology_ds(current_cytology, current_ds) : _cytology",
      "has_cytology_history": "(_cytology == 'Normal' || _cytology == 'ASC-US' || _cytology == 'LSIL') && (hpv == 'None')",
      "_cytology_history": "has_cytology_history ? cytology_history : ''"
    },
    {
      "prior_hpv": "(hpv != '' && hpv != 'None') ? (prior_hpv_positive ? 'Positive' : prior_hpv_negative ? 'Negative' : 'None') : 'None'",
      "prior_cytology": "!(hpv != '' && hpv != 'None') ? _cytology_history : prior_agc ? 'AGC' : prior_hsil ? 'HSIL' : prior_asc_h ? 'ASC-H' : prior_lsil ? 'LSIL' : prior_asc_us ? 'ASC-US' : prior_normal ? 'Normal' : 'None'",
      "past": "prior_hpv + '/' + prior_cytology"
    },
    {
      "current_cytology_count": "(current_agc ? 1 : 0) + (current_hsil ? 1: 0) + ( current_asc_h ? 1: 0) + (current_lsil ? 1 : 0) + (current_asc_us ? 1 : 0) + (current_normal ? 1 : 0)",
      "current_ds_count": "(current_dual_stain_positive ? 1 : 0) + (current_dual_stain_negative ? 1 : 0)",
      "prior_cytology_count": "(prior_agc ? 1 : 0) + (prior_hsil ? 1 : 0) + (prior_asc_h ? 1 : 0) + (prior_lsil ? 1: 0) + (prior_asc_us ? 1 : 0) + (prior_normal ? 1 : 0)",
      "prior_hpv_count": "(prior_hpv_positive ? 1 : 0) + (prior_hpv_negative ? 1 : 0)"
    }
  ],
